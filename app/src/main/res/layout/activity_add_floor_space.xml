<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F2F0">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#FFFFFF"
        app:title="Add Floor Space"
        app:titleTextColor="#1A1A1A"
        app:navigationIcon="@drawable/ic_back_white"
        app:navigationIconTint="#1A1A1A"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Floor Space Name"
                android:textColor="#888888"
                android:textSize="12sp"
                android:fontFamily="sans-serif"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/txtFloorSpaceName"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/field_bg"
                android:hint="e.g. Main Floor"
                android:textColor="#1A1A1A"
                android:textColorHint="#AAAAAA"
                android:textSize="14sp"
                android:fontFamily="sans-serif"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:inputType="textCapWords"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Width (m)"
                android:textColor="#888888"
                android:textSize="12sp"
                android:fontFamily="sans-serif"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/txtWidth"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/field_bg"
                android:hint="e.g. 3.5"
                android:textColor="#1A1A1A"
                android:textColorHint="#AAAAAA"
                android:textSize="14sp"
                android:fontFamily="sans-serif"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:inputType="numberDecimal"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Depth (m)"
                android:textColor="#888888"
                android:textSize="12sp"
                android:fontFamily="sans-serif"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/txtDepth"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/field_bg"
                android:hint="e.g. 3.2"
                android:textColor="#1A1A1A"
                android:textColorHint="#AAAAAA"
                android:textSize="14sp"
                android:fontFamily="sans-serif"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:inputType="numberDecimal"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Product"
                android:textColor="#888888"
                android:textSize="12sp"
                android:fontFamily="sans-serif"
                android:layout_marginBottom="6dp"/>

            <LinearLayout
                android:id="@+id/btnChooseProduct"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/field_bg"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/txtProductName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Choose Product"
                    android:textColor="#AAAAAA"
                    android:fontFamily="sans-serif"
                    android:textSize="14sp"/>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/arrow_down_float"
                    app:tint="#888888"/>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Estimated Price"
                android:textColor="#888888"
                android:textSize="12sp"
                android:fontFamily="sans-serif"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/txtEstimatedPrice"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/field_bg"
                android:text="Select product to calculate"
                android:textColor="#AAAAAA"
                android:fontFamily="sans-serif"
                android:textSize="14sp"
                android:paddingLeft="16dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnSave"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Save"
                    android:backgroundTint="#1B8A5A"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginRight="8dp"/>

                <Button
                    android:id="@+id/btnCancel"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Cancel"
                    android:backgroundTint="#F0F2F0"
                    android:textColor="#888888"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>