<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:id="@+id/main"
    android:background="#F8F8F8">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A1A2E"
        android:padding="28dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Floor Me 🏠"
            android:textColor="#C9A84C"
            android:textSize="36sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="We measure up so you don't have to 📏"
            android:textColor="#E0E0E0"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginTop="6dp"/>

    </LinearLayout>

    <!-- Projects label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="My Projects 📋"
        android:textColor="#1A1A2E"
        android:textSize="16sp"
        android:textStyle="bold"
        android:padding="16dp"
        android:letterSpacing="0.15"/>

    <!-- Empty state message -->
    <TextView
        android:id="@+id/txtEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No projects yet... don't be a square! 📐"
        android:textColor="#9E9E9E"
        android:textSize="16sp"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"/>

    <!-- List of houses -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/houseList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"/>

    <!-- Add new house button -->
    <Button
        android:id="@+id/btnAddHouse"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="+ New Project"
        android:layout_margin="16dp"
        android:backgroundTint="#1A1A2E"
        android:textColor="#C9A84C"
        android:textStyle="bold"
        android:textSize="18sp"/>

</LinearLayout>