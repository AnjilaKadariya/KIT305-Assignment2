<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:id="@+id/main"
    android:background="#0D1117">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0D1117"
        android:padding="20dp"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Floor Me "
            android:textColor="#00BFA5"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="We measure up so you don't have to "
            android:textColor="#8B949E"
            android:textSize="13sp"
            android:layout_marginTop="4dp"
            android:gravity="center"/>

    </LinearLayout>

    <!-- Search Bar -->
    <EditText
        android:id="@+id/searchBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/search_background"
        android:hint="🔍 Search by name or address..."

        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:inputType="text"/>

    <!-- Empty state message -->
    <TextView
        android:id="@+id/txtEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No projects yet... don't be a square! "
        android:textColor="#8B949E"
        android:textSize="15sp"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"/>

    <!-- List of houses -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/houseList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"/>

    <!-- Add new house button -->
    <Button
        android:id="@+id/btnAddHouse"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="+ New Project"
        android:layout_margin="16dp"
        android:backgroundTint="#00BFA5"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="16sp"/>

</LinearLayout>