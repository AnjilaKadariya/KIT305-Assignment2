<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D1117">

    <!-- Top AppBar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#1C2128"
        app:title="New Project"
        app:titleTextColor="#FFFFFF"
        app:navigationIcon="@drawable/ic_back"
        app:navigationIconTint="#00BFA5"/>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Customer Name -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Customer Name *"
                android:textColor="#8B949E"
                android:textSize="12sp"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/txtCustomerName"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/field_bg"
                android:hint="e.g. John Smith"
                android:textColor="#FFFFFF"
                android:textColorHint="#555555"
                android:textSize="14sp"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:inputType="textPersonName"
                android:layout_marginBottom="16dp"/>

            <!-- Phone Number -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Phone Number *"
                android:textColor="#8B949E"
                android:textSize="12sp"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/txtPhone"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/field_bg"
                android:hint="e.g. 0412 345 678"
                android:textColor="#FFFFFF"
                android:textColorHint="#555555"
                android:textSize="14sp"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:inputType="phone"
                android:maxLength="10"
                android:layout_marginBottom="16dp"/>

            <!-- Email -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Email Address (optional)"
                android:textColor="#8B949E"
                android:textSize="12sp"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/txtEmail"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/field_bg"
                android:hint="e.g. john@email.com"
                android:textColor="#FFFFFF"
                android:textColorHint="#555555"
                android:textSize="14sp"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:inputType="textEmailAddress"
                android:layout_marginBottom="16dp"/>

            <!-- Address -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Street Address *"
                android:textColor="#8B949E"
                android:textSize="12sp"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/txtAddress"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/field_bg"
                android:hint="e.g. 12 Philip Avenue"
                android:textColor="#FFFFFF"
                android:textColorHint="#555555"
                android:textSize="14sp"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:inputType="textPostalAddress"
                android:layout_marginBottom="16dp"/>

            <!-- Suburb and Postcode -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginRight="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Suburb *"
                        android:textColor="#8B949E"
                        android:textSize="12sp"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/txtSuburb"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/field_bg"
                        android:hint="Suburb"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#555555"
                        android:textSize="14sp"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:inputType="textCapWords"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Postcode *"
                        android:textColor="#8B949E"
                        android:textSize="12sp"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/txtPostcode"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/field_bg"
                        android:hint="0000"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#555555"
                        android:textSize="14sp"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:inputType="number"
                        android:maxLength="4"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Property Type -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Property Type *"
                android:textColor="#8B949E"
                android:textSize="12sp"
                android:layout_marginBottom="6dp"/>

            <Spinner
                android:id="@+id/spinnerPropertyType"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/field_bg"
                android:paddingLeft="16dp"
                android:popupBackground="#1C2128"/>

            <!-- Emergency Contact -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Emergency Contact (optional)"
                android:textColor="#8B949E"
                android:textSize="12sp"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/txtEmergencyContact"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/field_bg"
                android:hint="e.g. 0412 345 678"
                android:textColor="#FFFFFF"
                android:textColorHint="#555555"
                android:textSize="14sp"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:inputType="phone"
                android:layout_marginBottom="24dp"/>

            <!-- Save Button -->
            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Save Project"
                android:backgroundTint="#00BFA5"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="16sp"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>