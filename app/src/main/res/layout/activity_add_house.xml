<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F2F0">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#FFFFFF"
        app:title="New Project"
        app:titleTextColor="#1A1A1A"
        app:navigationIcon="@drawable/ic_back_white"
        app:navigationIconTint="#1A1A1A">

        <ImageButton
            android:id="@+id/btnDeleteHouse"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="end"
            android:src="@drawable/ic_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="6dp"
            android:layout_marginEnd="12dp"
            app:tint="#CC0000"
            android:visibility="gone"/>

    </androidx.appcompat.widget.Toolbar>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Customer Name *"
                android:textColor="#888888"
                android:textSize="12sp"
                android:fontFamily="sans-serif"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/txtCustomerName"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/field_bg"
                android:hint="e.g. John Smith"
                android:textColor="#1A1A1A"
                android:textColorHint="#AAAAAA"
                android:textSize="14sp"
                android:fontFamily="sans-serif"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:inputType="textPersonName"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Phone Number *"
                android:textColor="#888888"
                android:textSize="12sp"
                android:fontFamily="sans-serif"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/txtPhone"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/field_bg"
                android:hint="e.g. 0412 345 678"
                android:textColor="#1A1A1A"
                android:textColorHint="#AAAAAA"
                android:textSize="14sp"
                android:fontFamily="sans-serif"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:inputType="phone"
                android:maxLength="10"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Email Address (optional)"
                android:textColor="#888888"
                android:textSize="12sp"
                android:fontFamily="sans-serif"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/txtEmail"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/field_bg"
                android:hint="e.g. john@email.com"
                android:textColor="#1A1A1A"
                android:textColorHint="#AAAAAA"
                android:textSize="14sp"
                android:fontFamily="sans-serif"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:inputType="textEmailAddress"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Street Address *"
                android:textColor="#888888"
                android:textSize="12sp"
                android:fontFamily="sans-serif"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/txtAddress"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/field_bg"
                android:hint="e.g. 12 Philip Avenue"
                android:textColor="#1A1A1A"
                android:textColorHint="#AAAAAA"
                android:textSize="14sp"
                android:fontFamily="sans-serif"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:inputType="textPostalAddress"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginRight="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Suburb *"
                        android:textColor="#888888"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/txtSuburb"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/field_bg"
                        android:hint="Suburb"
                        android:textColor="#1A1A1A"
                        android:textColorHint="#AAAAAA"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:inputType="textCapWords"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Postcode *"
                        android:textColor="#888888"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/txtPostcode"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/field_bg"
                        android:hint="0000"
                        android:textColor="#1A1A1A"
                        android:textColorHint="#AAAAAA"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:inputType="number"
                        android:maxLength="4"/>

                </LinearLayout>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Property Type *"
                android:textColor="#888888"
                android:textSize="12sp"
                android:fontFamily="sans-serif"
                android:layout_marginBottom="6dp"/>

            <Spinner
                android:id="@+id/spinnerPropertyType"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/field_bg"
                android:paddingLeft="16dp"
                android:popupBackground="#FFFFFF"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Emergency Contact (optional)"
                android:textColor="#888888"
                android:textSize="12sp"
                android:fontFamily="sans-serif"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/txtEmergencyContact"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/field_bg"
                android:hint="e.g. 0412 345 678"
                android:textColor="#1A1A1A"
                android:textColorHint="#AAAAAA"
                android:textSize="14sp"
                android:fontFamily="sans-serif"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:inputType="phone"
                android:layout_marginBottom="24dp"/>

            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Save Project"
                android:backgroundTint="#1B8A5A"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:textSize="16sp"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>